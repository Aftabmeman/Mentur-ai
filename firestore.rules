rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * Simplified to a robust user-siloed architecture.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Data Silo ---
    // This recursive wildcard rule covers ALL data under a user's node:
    // /users/{userId}/profile/stats
    // /users/{userId}/study_materials/*
    // /users/{userId}/assessments/*
    // /users/{userId}/assessments/*/questions/*
    // /users/{userId}/assessment_attempts/*
    // /users/{userId}/submitted_essays/*
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
  }
}