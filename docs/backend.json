
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user-specific profile information and statistics.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "The full name of the user."
        },
        "coinBalance": {
          "type": "number",
          "description": "Current available coins in the wallet."
        },
        "dailyCoinsUsed": {
          "type": "number",
          "description": "Coins spent today (capped at 5)."
        },
        "lastDailyReset": {
          "type": "string",
          "format": "date-time"
        },
        "lastMonthlyAllowance": {
          "type": "string",
          "format": "date-time"
        },
        "assessmentsDone": {
          "type": "number",
          "description": "Total number of assessments completed."
        },
        "level": {
          "type": "string",
          "description": "User's current academic level."
        },
        "preferredLanguage": {
          "type": "string",
          "description": "The user's preferred language."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "StudyMaterial": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudyMaterial",
      "type": "object",
      "description": "Represents a piece of study material ingested by the user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "contentType": {
          "type": "string"
        },
        "textContent": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "uploadDate": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "title",
        "contentType"
      ]
    },
    "Assessment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Assessment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "studyMaterialId": { "type": "string" },
        "title": { "type": "string" },
        "assessmentType": { "type": "string" },
        "academicLevel": { "type": "string" },
        "difficulty": { "type": "string" },
        "generatedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google",
      "email_link",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/profile/stats",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profile stats. Document ID is 'stats'.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/study_materials/{studyMaterialId}",
        "definition": {
          "entityName": "StudyMaterial",
          "schema": {
            "$ref": "#/backend/entities/StudyMaterial"
          },
          "description": "Stores study materials owned by the user.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            },
            {
              "name": "studyMaterialId",
              "description": "Unique ID for the material."
            }
          ]
        }
      }
    ]
  }
}
